<view class="tab-bar">
  <!-- 背景图片 -->
  <image class="tab-bar-bg" src="/static/下目录栏.png" mode="aspectFill"></image>
  
  <!-- tabbar内容 -->
  <block wx:for="{{list}}" wx:key="index">
    <view class="tab-item {{selected === index ? 'active' : ''}}" bindtap="onTabTap" data-index="{{index}}">
      <image class="icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" mode="aspectFit" />
      <text class="text">{{item.text}}</text>

      <!-- 显示红点数字 -->
      <view
        wx:if="{{index === 2 && item.badge > 0 && item.badge <= 99}}"
        class="badge"
      >
        {{item.badge}}
      </view>

      <!-- 显示超过99的红点 -->
      <view
        wx:elif="{{index === 2 && item.badge > 99}}"
        class="badge"
      >
        99+
      </view>
    </view>
  </block>
</view>
