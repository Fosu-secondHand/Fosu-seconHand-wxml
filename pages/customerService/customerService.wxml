<view class="container">
  <custom-nav-bar title="客服中心" showBack="true" />
  
  <view style="padding-top: 88rpx;">
    <!-- 客服入口 -->
    <view class="service-entry">
      <!-- ✅ 修改：使用微信客服按钮 -->
      <button class="service-button" open-type="contact" session-from="customerService">
        <image src="/static/assets/icons/customer.png"></image>
        <text>联系在线客服</text>
      </button>

      <view class="service-item" bindtap="sendEmail">
        <image src="/static/assets/icons/email.png"></image>
        <text>邮件咨询</text>
        <text class="email">fosu_secondhand@163.com</text>
        <view class="arrow"></view>
      </view>
    </view>

    <!-- 常见问题 -->
    <view class="faq-container">
      <view class="faq-title">常见问题</view>
      <view class="faq-list">
        <block wx:for="{{faqList}}" wx:key="id">
          <view class="faq-item">
            <view class="question" bindtap="toggleFaq" data-id="{{item.id}}">
              <text>{{item.question}}</text>
              <image src="{{item.expanded ? '/static/assets/icons/arrowdown.png' : '/static/assets/icons/arrowright.png'}}"></image>
            </view>
            <view class="answer {{item.expanded ? 'show' : 'hide'}}">
              <text>{{item.answer}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
